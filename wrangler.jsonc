{
	"compatibility_date": "2026-04-25",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "individual-life",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "individual-life.org",
			"custom_domain": true
		}
	]
}